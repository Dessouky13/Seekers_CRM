# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://seekers:YOUR_DB_PASSWORD@localhost:5432/seekersai

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=your-256-bit-random-secret-at-least-32-characters-long
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Brevo SMTP ────────────────────────────────────────────
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your-brevo-login@example.com
BREVO_SMTP_PASS=your-brevo-smtp-key
EMAIL_FROM=Team@seekersai.org
EMAIL_FROM_NAME=Seekers AI

# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=https://app.seekersai.org

# ── File Storage ──────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ── Redis (local) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── App URL (for file serving) ────────────────────────────
API_BASE_URL=http://localhost:3000

# ── Notifications / Automation ───────────────────────────
AUTOMATION_API_KEY=replace-with-random-long-secret
LEAD_NO_RESPONSE_HOURS=48
STALE_LEAD_SWEEP_MINUTES=10

# ── Task Cleanup ─────────────────────────────────────────
# Auto-delete tasks completed more than N days ago (0 disables)
TASK_AUTO_DELETE_DAYS=30
TASK_CLEANUP_SWEEP_MINUTES=60
